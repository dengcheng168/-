# 浏览器端可访问的后端 API 地址（经 Nginx 反代，生产环境通常是同域名下的 /api）
NEXT_PUBLIC_API_BASE_URL=/api

# 服务端渲染时使用的后端地址：
# - 本地开发：直接指向本地运行的 Fastify 后端
# - Docker 生产环境：指向内部网络的 backend 服务（见根目录 docker-compose.yml）
INTERNAL_API_BASE_URL=http://localhost:4000

# 站点基础 URL，用于生成 canonical/OG/sitemap 等绝对地址
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 后端 /uploads 静态文件的浏览器可访问地址前缀：
# - 生产环境留空（Nginx 与前端同域名，/uploads/xxx 直接可用相对路径）
# - 本地开发填后端地址，因为前端(3000)和后端(4000)是不同源，相对路径无法跨源解析
NEXT_PUBLIC_UPLOADS_BASE_URL=http://localhost:4000

# 定期自动清理全站缓存（等价于后台"缓存管理"页手动点一次）的间隔，单位小时。
# 可选，不设置则默认 24 小时。见 src/instrumentation.ts。
CACHE_AUTO_CLEAR_INTERVAL_HOURS=24
