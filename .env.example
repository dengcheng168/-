# =============================================================================
# 根目录环境变量 —— 供 docker-compose.yml / docker-compose.prod.yml 读取
# 部署前复制为 .env 并修改所有默认值，尤其是密码和密钥
# =============================================================================

# ---- 通用 ----
NODE_ENV=production
# 生产环境请填写真实域名，例如 example.com（用于 Nginx server_name 与前端 URL 生成）
DOMAIN_NAME=localhost

# ---- 对外端口（仅 Nginx 容器会暴露）----
# 如果服务器上已经有宝塔/1Panel 等面板占用了 80/443（面板自带的 Nginx 负责域名转发和 SSL 证书），
# 把这两个值改成"只监听本机回环地址"，避免端口冲突，例如：
#   HTTP_PORT=127.0.0.1:8080
#   HTTPS_PORT=127.0.0.1:8443
# 然后在面板里新建一个"反向代理"站点，把域名代理到 http://127.0.0.1:8080 即可，SSL 证书也由面板签发。
HTTP_PORT=80
HTTPS_PORT=443

# ---- 后端 ----
# JWT 签名密钥，生产环境必须替换为随机长字符串（例如 openssl rand -base64 48）
JWT_SECRET=please-change-this-to-a-random-secret
# JWT 过期时间
JWT_EXPIRES_IN=7d
# 允许跨源请求的前端源（本地开发直连后端时需要；生产环境经 Nginx 同源反代，一般不需要跨源）
CORS_ORIGIN=http://localhost:3000
# 决定按 IP 限流/登录锁定信任哪些来源的 X-Forwarded-For，默认值适合"前面就是自己人反向代理"
# 的部署方式（Docker 内部网络/宿主机反代），一般不需要改
TRUST_PROXY=loopback, uniquelocal

# ---- 管理员账号初始化（仅 create-admin 脚本首次运行时使用）----
ADMIN_INIT_EMAIL=admin@example.com
ADMIN_INIT_PASSWORD=please-change-this-password

# ---- 前端（会在 Docker 构建阶段写死进静态产物，修改后需要 docker compose build 重新构建）----
# 浏览器端可访问的后端 API 地址，经 Nginx 反代，同域名下用相对路径即可
NEXT_PUBLIC_API_BASE_URL=/api
# [deprecated] 站点对外访问的完整地址：正式的事实源现在是后台"SEO 设置 -> 正式站点域名"
# （SiteSetting.siteBaseUrl），运行时故障回退用下面的 SITE_URL（不需要重新 build）。
# 这个变量只在数据库配置和 SITE_URL 都缺失时才会被读取，作为迁移期的最后一层兼容，
# 计划后续版本移除，新的部署不需要再设置它，保留默认值即可。
NEXT_PUBLIC_SITE_URL=http://localhost
# 后端 /uploads 静态文件的浏览器可访问地址前缀：生产环境与前端同域名，留空即可
NEXT_PUBLIC_UPLOADS_BASE_URL=

# ---- 正式站点域名（Runtime Site Domain Configuration，运行时读取，不需要重新 build）----
# 首选：部署后直接在后台"全站设置 -> SEO 与追踪 -> 正式站点域名"里配置，只有超级管理员能改，
# 保存后自动刷新 SEO 缓存，立即生效。
# SITE_URL 是数据库配置缺失/不可用时的服务器运行时故障回退，同样不需要重新 build，
# 只需要 docker compose restart frontend。生产环境请填写真实域名，例如 https://koigatetech.com
SITE_URL=
# 后台保存正式站点域名后，backend 用这个密钥调用 frontend 触发缓存刷新，两边必须一致，
# 生产环境务必生成一个随机长字符串（例如 openssl rand -base64 32），不要留空
REVALIDATE_SECRET=

# ---- 可选：Cloudflare Turnstile（询盘表单防机器人）----
# 注意：这两个变量目前不会被后端读取——实际生效的密钥保存在数据库（后台"全站设置"页配置），
# 这里留空即可，只是为了让 `docker compose config` 展示完整的变量清单，不需要手动填写
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---- 可选：SMTP 询盘邮件提醒 ----
# 同上：实际生效的 SMTP 配置保存在数据库（后台"全站设置"页配置），这里留空即可
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
