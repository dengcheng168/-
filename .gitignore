# Dependencies
node_modules/
**/node_modules/

# Build output
.next/
dist/
build/

# Env files
.env
.env.local
.env.production
**/.env
**/.env.local
!.env.example
!**/.env.example

# Data & uploads (persisted volumes, not part of the repo)
/data/*
!/data/.gitkeep
/uploads/*
!/uploads/.gitkeep

# 后端本地开发上传目录（映射到生产环境的挂载卷，不进仓库）
backend/uploads/*
!backend/uploads/.gitkeep

# Backup archives generated by scripts/backup.sh
/backups/

# TLS certificates and ACME challenge files (sensitive / host-specific)
/nginx/letsencrypt/*
!/nginx/letsencrypt/.gitkeep
/nginx/certbot-webroot/*
!/nginx/certbot-webroot/.gitkeep

# Logs
logs/
*.log
npm-debug.log*

# Prisma
backend/prisma/dev.db
backend/prisma/dev.db-journal
*.db
*.db-journal
*.db-wal
*.db-shm

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Test/coverage
coverage/

# TypeScript build info
*.tsbuildinfo
