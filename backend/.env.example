# 后端本地开发环境变量（Docker Compose 场景下由根目录 .env 覆盖注入）
NODE_ENV=development
HOST=0.0.0.0
BACKEND_PORT=4000
LOG_LEVEL=info

# CORS 允许的前端源，多个用逗号分隔
CORS_ORIGIN=http://localhost:3000

# 决定 request.ip（限流/登录锁定/操作日志用的客户端 IP）信任哪些来源的 X-Forwarded-For，
# 默认只信任回环地址和私网地址段（对应 Docker 内部网络/宿主机反代这种部署方式）。
# 不填则使用这个默认值，逗号分隔，支持 proxy-addr 预设名（loopback/linklocal/uniquelocal）和具体 IP/CIDR。
TRUST_PROXY=loopback, uniquelocal

# 数据库（路径相对于 prisma/schema.prisma 所在目录解析，因此不要再加 prisma/ 前缀）
#
# 项目继续使用 SQLite（不是 MySQL/PostgreSQL），三种环境各用一个独立的 .db 文件，不共用：
#   - 本地开发（本文件）：file:./dev.db，即 backend/prisma/dev.db
#   - 自动化测试（`npm test`）：不要在这里手工配置，也不要复制这个值给测试用——测试由
#     test/bootstrap.ts 在每个测试文件独立进程里自动创建一个系统临时目录下的隔离 SQLite 文件
#     （例如 /tmp/koigate-tests-xxxx/test.db），运行结束自动删除，跑完之后 dev.db 不会有任何变化。
#     backend/src/lib/database-safety.ts 会在 NODE_ENV=test 时强制校验 DATABASE_URL 必须指向
#     这种隔离临时库，指向 dev.db 或生产库都会直接拒绝启动。
#   - 生产（Docker）：由 docker-compose.yml 里 backend 服务的 environment 直接指定为
#     file:/app/data/production.db（不是从这个 .env.example 或根目录 .env 读取），对应
#     ./data:/app/data 的持久化挂载卷，见根目录 docker-compose.yml 注释。
DATABASE_URL=file:./dev.db

# 鉴权（阶段4启用）
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=7d

# 管理员账号初始化（阶段4 create-admin 脚本使用）
ADMIN_INIT_EMAIL=admin@example.com
ADMIN_INIT_PASSWORD=change-me-please

# 上传目录（阶段5启用）
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# 可选：Cloudflare Turnstile —— 注意：这两个变量目前不会被读取，实际生效的密钥保存在数据库
# （后台"全站设置"页配置），这里留空即可
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# 可选：SMTP 询盘邮件提醒 —— 同上，实际生效的配置保存在数据库（后台"全站设置"页配置），这里留空即可
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# Runtime Site Domain Configuration：保存正式站点域名后，backend 调用 frontend 触发缓存刷新
# 本机开发时前后端分属不同端口，默认值就是本机 frontend dev server 地址
FRONTEND_BASE_URL=http://localhost:3000
# 必须和 frontend 的同名变量一致，本机开发留空也能跑（frontend 会把请求当未授权处理，
# 只影响缓存刷新这一步，不影响域名本身保存成功）
REVALIDATE_SECRET=
