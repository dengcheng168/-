# 后端本地开发环境变量（Docker Compose 场景下由根目录 .env 覆盖注入）
NODE_ENV=development
HOST=0.0.0.0
BACKEND_PORT=4000
LOG_LEVEL=info

# CORS 允许的前端源，多个用逗号分隔
CORS_ORIGIN=http://localhost:3000

# 数据库（路径相对于 prisma/schema.prisma 所在目录解析，因此不要再加 prisma/ 前缀）
DATABASE_URL=file:./dev.db

# 鉴权（阶段4启用）
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=7d

# 管理员账号初始化（阶段4 create-admin 脚本使用）
ADMIN_INIT_EMAIL=admin@example.com
ADMIN_INIT_PASSWORD=change-me-please

# 上传目录（阶段5启用）
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# 可选：Cloudflare Turnstile（阶段5启用）
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# 可选：SMTP 询盘邮件提醒（阶段5启用）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
