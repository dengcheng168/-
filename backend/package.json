{
  "name": "water-purifier-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "seed:translations": "tsx prisma/seed-translations.ts",
    "migrate:faq-translations": "tsx prisma/migrate-faq-translations.ts",
    "backfill:site-base-url": "tsx prisma/backfill-site-base-url.ts",
    "create-admin": "tsx scripts/create-admin.ts",
    "test": "node --import tsx --import ./test/bootstrap.ts --test test/*.test.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/static": "^8.0.3",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/sensible": "^6.0.2",
    "@prisma/client": "^6.19.3",
    "argon2": "^0.41.1",
    "sharp": "^0.33.5",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.0.1",
    "nodemailer": "^6.9.16",
    "sanitize-html": "^2.13.1",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^6.4.16",
    "@types/sanitize-html": "^2.13.0",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "eslint": "^8.57.1",
    "pino-pretty": "^11.3.0",
    "prettier": "^3.3.3",
    "prisma": "^6.19.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "allowScripts": {
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "esbuild@0.28.1": true,
    "prisma@6.19.3": true,
    "argon2@0.41.1": true,
    "sharp@0.33.5": true
  }
}
